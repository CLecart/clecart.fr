{
  "name": "clecart-portfolio",
  "version": "1.0.0",
  "description": "Portfolio professionnel de Christophe Lecart - Software Engineer & Green IT Lead",
  "main": "index.html",
  "type": "module",
  "scripts": {
    "start": "python3 -m http.server 8000",
    "docker:build": "docker build -t clecart-portfolio .",
    "docker:run": "docker run -d -p 8080:80 --name clecart-portfolio-container clecart-portfolio",
    "docker:stop": "docker stop clecart-portfolio-container && docker rm clecart-portfolio-container",
    "docker:logs": "docker logs clecart-portfolio-container",
    "lighthouse": "npx lighthouse http://localhost:8000 --output html --output-path ./lighthouse-report.html",
    "lint": "eslint js service-worker.js",
    "lint:fix": "eslint js service-worker.js --fix",
    "format": "prettier --write \"js/**/*.js\" \"css/**/*.css\" styles.css service-worker.js eslint.config.js",
    "format:check": "prettier --check \"js/**/*.js\" \"css/**/*.css\" styles.css service-worker.js eslint.config.js",
    "deploy": "./deploy.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CLecart/clecart.fr.git"
  },
  "keywords": [
    "portfolio",
    "javascript",
    "css3",
    "html5",
    "responsive",
    "performance",
    "accessibility",
    "pwa"
  ],
  "author": "Christophe Lecart <contact@clecart.fr>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CLecart/clecart.fr/issues"
  },
  "homepage": "https://clecart.fr",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-jsdoc": "^63.0.13",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "puppeteer": "^24.40.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
